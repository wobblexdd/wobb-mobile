{
  "name": "wobb-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "Self-hosted WOBB mobile client for VLESS / REALITY",
  "main": "index.js",
  "scripts": {
    "start": "react-native start --config metro.config.js",
    "android": "react-native run-android",
    "reverse": "adb reverse tcp:3000 tcp:3000",
    "android:clean": "node scripts/android-gradle.js clean",
    "android:debug-apk": "node scripts/android-gradle.js assembleDebug",
    "android:release-apk": "node scripts/android-gradle.js assembleRelease",
    "android:release-bundle": "node scripts/android-gradle.js bundleRelease",
    "android:install-debug": "node scripts/android-gradle.js installDebug"
  },
  "license": "MIT",
  "dependencies": {
    "react": "^19.2.4",
    "react-native": "^0.85.0"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.1.3",
    "@react-native/babel-preset": "^0.85.0",
    "@react-native/metro-config": "^0.85.0"
  }
}
